[global]
    font = JetBrains Mono 10
    frame_width = 2
    separator_height = 2
    padding = 8
    horizontal_padding = 8
    corner_radius = 0
    frame_color = "#ffffff" 
    offset = 10x50

[urgency_low]
    background = "#000000"
    foreground = "#888888"
    timeout = 5

[urgency_normal]
    background = "#000000"
    foreground = "#ffffff"
    timeout = 10

[urgency_critical]
    background = "#ffffff"
    foreground = "#000000"
    frame_color = "#ffffff"
    timeout = 0
