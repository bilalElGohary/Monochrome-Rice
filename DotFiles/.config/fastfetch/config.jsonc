{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "source": "~/.config/fastfetch/ascii0.txt",
        "padding": {
            "top": 1,
            "right": 6
        	},
    	"color": {
       	 "1": "white"
   	 }
   	 },
  	  "display": {
    	    "separator": " •  "
	    },    "modules": [
		"break",
		{
	       "type": "os",
	       "key": "OS  ",
	       "keyColor": "31",
	    },
		{
            "type": "cpu",
            "modules": "cpu",
            "key": "CPU ",
            "keyColor": "33",
        },
        {
            "type": "gpu",
            "modules": "gpu",
            "key": "GPU ",
            "keyColor": "35",
             },
        {
                    "type": "memory",
                    "modules": "memory",
                    "key": "RAM ",
                    "keyColor": "36",
                     },
        {
            "type": "kernel",
            "key": "KER ",
            "keyColor": "32",
        },
        {
            "type": "wm",
            "key": "WM  ",
            "keyColor": "36", 
        },
		{
            "type": "uptime",
            "format": "{2}h {3}m",
            "key": "UT  ",
            "keyColor": "32",
        },
        "break",
    ]
}
